NEXT_PUBLIC_FORM_ENDPOINT=

# If set, the contact form will submit to this endpoint and then redirect to /zh/contact/thanks.
# If left empty, the contact page will show real contact options instead of pretending the form submitted successfully.

# Media CDN base URL (Cloudflare R2 public bucket)
# Leave empty for local dev — videos will be served from /public/videos/
# In production (Vercel), set this to the R2 public URL:
#   https://pub-750866849946432cb842827f7414652c.r2.dev
NEXT_PUBLIC_MEDIA_BASE=
