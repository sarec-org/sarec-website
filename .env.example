NEXT_PUBLIC_FORM_ENDPOINT=

# If set, the contact form will submit to this endpoint and then redirect to /zh/contact/thanks.
# If left empty, the contact page will show real contact options instead of pretending the form submitted successfully.

# Media CDN base URL (Cloudflare R2 public bucket)
# Leave empty for local dev — videos will be served from /public/videos/
# In production (Vercel), set this to the R2 public URL:
#   https://pub-750866849946432cb842827f7414652c.r2.dev
NEXT_PUBLIC_MEDIA_BASE=

# ==================================================================
# Membership / Strategic Partner V1 (Gate 2) — server-only secrets.
# NEVER commit real values. Put local values only in .env.local
# (gitignored). Set production values in Vercel project env vars.
# M3 (checkout) reads: DATABASE_URL, STRIPE_SECRET_KEY, NEXT_PUBLIC_SITE_URL.
# M4 (webhook) also reads: STRIPE_WEBHOOK_SECRET (from `stripe listen`, whsec_...).
# The rest (Resend, admin, cron) are wired in later milestones.
# ==================================================================

# Postgres connection string (Vercel Postgres / Neon). Server-only.
DATABASE_URL=

# Stripe (M3+). Server-only except the publishable key.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend transactional email (M7+). Server-only.
RESEND_API_KEY=
SAREC_ADMIN_EMAIL=
SAREC_FROM_EMAIL=

# Admin action token — guards the future admin "mark paid" API (M6+).
# Server-only; compared in constant time; never placed in a URL query.
ADMIN_ACTION_TOKEN=

# Cron secret — guards the future Vercel Cron reminder endpoint (M8+).
CRON_SECRET=

# Public site URL, used to build absolute links (checkout return, emails).
NEXT_PUBLIC_SITE_URL=
